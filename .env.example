# Copy to .env on the VM and fill in. Used by docker-compose.yml (api + streamlit).

# Required: same value for Streamlit (X-API-Key) and API (verification).
SCRAPER_API_KEY=change-me-to-a-long-random-secret

# Optional: Google Places / map tiles / geocode on the API
GOOGLE_MAPS_API_KEY=
# Optional managed HTML fetch provider (vendor page fallback)
SCRAPINGBEE_API_KEY=

# Worker-style tuning (optional; see env.worker.example for full list)
SCRAPER_WALL_CLOCK_SEC=2400
SCRAPER_MAX_CONCURRENT_SCRAPES=1
MAX_SCRAPE_SAMPLE_POINTS=150
SCRAPER_HIGH_VOLUME=1
SCRAPER_HTTP_LISTING_PAGES=25
SCRAPER_HTTP_LISTING_MAX_PATHS=1500
SCRAPER_PLAYWRIGHT_LISTING_SEED=1
SCRAPER_PLAYWRIGHT_SEED_URLS=12
SCRAPER_LISTING_PAGE_PAGINATION=1
SCRAPER_LISTING_MAX_PAGES=40
SCRAPER_LISTING_SCROLL_ROUNDS=35
SCRAPER_AGGRESSIVE_LISTING=1
SCRAPER_MIN_GRID_POINTS=150
SCRAPER_HIGH_VOLUME_MIN_SAMPLES=150
SCRAPER_PLAYWRIGHT_CONCURRENCY=5
RESTAURANT_DETAIL_ENRICH_MAX=400

# Optional: “Build:” line in the Streamlit header (compose default if unset)
# APP_BUILD_STAMP=git-abc1234
