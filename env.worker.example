# Template for env.worker.local (gitignored). Copy on the VPS:
#   bash scripts/bootstrap_worker_env.sh
# docker-compose.worker.yml loads env.worker.local only.
#
# Policy: restaurants only — listing hubs are /restaurants (+ cuisines); /uae/ slugs exclude groceries, mart, pharmacy, …
# Rows: one per branch URL (same brand, many locations) when dedupe_by_vendor_url=false (API default).

SCRAPER_API_KEY=

# Force dense grid + cuisine sweep even if a client omits high_volume (worker-only convenience).
SCRAPER_HIGH_VOLUME=1
SCRAPER_HIGH_VOLUME_MIN_SAMPLES=150

# Long wall clock for 10 km + many samples (raise if jobs still time out).
SCRAPER_WALL_CLOCK_SEC=2400

# Playwright vendor pages (phone, hours, …) when API request has enrich=true
SCRAPER_VENDOR_PAGE_ENRICH=1
RESTAURANT_DETAIL_ENRICH_MAX=400
SCRAPER_VENDOR_ENRICH_HARD_CAP=2000
SCRAPER_ENRICH_ABSOLUTE_MAX=250
SCRAPER_ENRICH_TOP_N=200

# Listing discovery
SCRAPER_LISTING_SEED_FULL_HUBS=1
SCRAPER_LISTING_SEED_MAX_HUB_URLS=24
SCRAPER_PLAYWRIGHT_LISTING_SEED=1
SCRAPER_PLAYWRIGHT_SEED_URLS=12
SCRAPER_HTTP_LISTING_PAGES=25
SCRAPER_HTTP_LISTING_MAX_PATHS=1500
SCRAPER_LISTING_PAGE_PAGINATION=1
SCRAPER_LISTING_MAX_PAGES=40
SCRAPER_LISTING_SCROLL_ROUNDS=35
SCRAPER_AGGRESSIVE_LISTING=1

# At most this many scrapes execute in parallel (1 = safest on a small VPS; raise only if you add CPU/RAM).
SCRAPER_MAX_CONCURRENT_SCRAPES=1

# Grid / points (tune per VM CPU; high = longer runs).
MAX_SCRAPE_SAMPLE_POINTS=150
SCRAPER_MIN_GRID_POINTS=150
SCRAPER_MAX_SAMPLE_POINTS_CAP_API=400
SCRAPER_PER_POINT_TIMEOUT_SEC=120
SCRAPER_PLAYWRIGHT_CONCURRENCY=5

# Human-like pacing (reduces WAF friction on a good IP).
SCRAPER_HUMANIZE=1

# Resume long runs
SCRAPER_ENABLE_CHECKPOINTS=1

# Optional: Google Places backfill for gaps when key is set
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_ENRICH=1

# Optional managed HTML fetch provider (used when REMOTE_VENDOR_HTML auto-detects a provider key)
SCRAPINGBEE_API_KEY=
SCRAPINGBEE_RENDER_JS=1
SCRAPINGBEE_COUNTRY_CODE=ae

# Optional Scrape.do rotating proxy (requests + Playwright). Omit SCRAPER_HTTP_PROXY to use this.
# SCRAPE_DO_TOKEN=
# SCRAPE_DO_PROXY_PASSWORD=customHeaders=false
# SCRAPE_DO_PROXY_HOST=proxy.scrape.do
# SCRAPE_DO_PROXY_PORT=8080
